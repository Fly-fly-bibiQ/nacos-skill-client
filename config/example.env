# Nacos Skill Client — 环境变量配置示例
# 复制为 .env 并填入实际值
# 所有环境变量名以 NACOS_SKILL_ 为前缀

# ==================== Nacos 配置 ====================
# Nacos 配置
# 注意：嵌套字段使用双下划线（__）分隔
NACOS_SKILL_NACOS__SERVER_ADDR=http://192.168.1.118:8002
NACOS_SKILL_NACOS__API_ADDR=http://192.168.1.118:8848
NACOS_SKILL_NACOS__USERNAME=nacos
NACOS_SKILL_NACOS__PASSWORD=nacos
NACOS_SKILL_NACOS__NAMESPACE_ID=public
NACOS_SKILL_NACOS__VERIFY_SSL=true

# LLM 配置
NACOS_SKILL_LLM__BASE_URL=http://192.168.1.118:8000/v1
NACOS_SKILL_LLM__MODEL=Qwen3.6-35B-A3B-FP8
NACOS_SKILL_LLM__API_KEY=dummy
NACOS_SKILL_LLM__TEMPERATURE=0.1
NACOS_SKILL_LLM__MAX_TOKENS=4096
NACOS_SKILL_LLM__TIMEOUT=120

# API 服务配置
NACOS_SKILL_API__HOST=0.0.0.0
NACOS_SKILL_API__PORT=8899

# 日志配置
NACOS_SKILL_LOGGING__LEVEL=INFO
